<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.github.mimiknight.monkey.mapper.ArticleMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.github.mimiknight.monkey.model.entity.ArticleEntity">
        <id column="id" property="id"/>
        <result column="title" property="title" jdbcType="VARCHAR"/>
        <result column="article" property="article" jdbcType="VARCHAR"/>
        <result column="audit" property="audit" jdbcType="TINYINT"/>
        <result column="deleted" property="deleted" jdbcType="TINYINT"/>
        <result column="created_time" property="createdTime" jdbcType="VARCHAR"
                typeHandler="com.github.mimiknight.monkey.common.mybatis.typehandler.MyZonedDateTimeTypeHandler"/>
        <result column="updated_time" property="updatedTime" jdbcType="VARCHAR"
                typeHandler="com.github.mimiknight.monkey.common.mybatis.typehandler.MyZonedDateTimeTypeHandler"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="BaseColumnList">
        id, title, article, audit, deleted, created_time, updated_time
    </sql>

    <select id="selectAuditingArticleByIds" resultType="com.github.mimiknight.monkey.model.entity.ArticleEntity">
        SELECT
        <include refid="BaseColumnList"/>
        FROM t_monkey_article
        WHERE audit = 1 AND id IN
        <foreach collection="articleIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="getEntityById" resultMap="BaseResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM t_monkey_article
        WHERE id = #{id}
    </select>

    <update id="audit">
        UPDATE t_monkey_article
        SET audit = #{auditResult}
        WHERE id IN
        <foreach collection="articleIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <update id="updateArticleById">
        UPDATE t_monkey_article
        SET title        = #{title},
            article      = #{article},
            updated_time = #{updatedTime,jdbcType=VARCHAR}
        WHERE id = #{id}
    </update>

    <insert id="save">
        INSERT INTO t_monkey_article (id, title, article, created_time, updated_time)
            VALUE (#{id}, #{title}, #{article}, #{createdTime,jdbcType=VARCHAR}, #{updatedTime,jdbcType=VARCHAR});
    </insert>

</mapper>
